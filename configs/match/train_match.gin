AVA_HEAD_CROP_WIDTH = 512
HEAD_CROP_OFFSET_Y = -64
INPUT_RES = %AVA_HEAD_CROP_HEIGHT
OUTPUT_RES = %INPUT_RES
IMG_PATCH_SIZE = 8
